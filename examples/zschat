#!/usr/bin/java --class-path=../zsmith/zbo/zsmith.jar --source 25

import airhacks.zsmith.tui.boundary.Chat;

void main(String... args) {
    var port = Arrays
                .stream(args)
                .findFirst()
                .map(Integer::parseInt)
                .orElse(8080);
    new Chat()
            .withPort(port)
            .start();
}
